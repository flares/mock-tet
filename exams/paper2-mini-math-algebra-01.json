  "questions": [
    {
      "id": "q1",
      "sectionId": "math",
      "globalIndex": 0,
      "text": "Which of the following pairs consists of like terms?",
      "options": [
        {
          "key": "A",
          "text": "3x²y and 5xy²"
        },
        {
          "key": "B",
          "text": "7ab and -2ba"
        },
        {
          "key": "C",
          "text": "4p²q and 4pq²"
        },
        {
          "key": "D",
          "text": "9mn and 9m"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Like terms have identical variable parts with the same exponents; 7ab and -2ba both have variables a and b to the first power, so they are like terms."
    },
    {
      "id": "q2",
      "sectionId": "math",
      "globalIndex": 1,
      "text": "The coefficient of x in the expression 5 - 7x + 3x²y - 2xy is:",
      "options": [
        {
          "key": "A",
          "text": "-7"
        },
        {
          "key": "B",
          "text": "3"
        },
        {
          "key": "C",
          "text": "-7 - 2y"
        },
        {
          "key": "D",
          "text": "-9"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Collecting all terms containing x to the first power: -7x - 2xy = (-7 - 2y)x, so the coefficient of x is -7 - 2y."
    },
    {
      "id": "q3",
      "sectionId": "math",
      "globalIndex": 2,
      "text": "Simplify: (4a² - 3a + 7) - (2a² + 5a - 4)",
      "options": [
        {
          "key": "A",
          "text": "2a² - 8a + 11"
        },
        {
          "key": "B",
          "text": "2a² + 2a + 3"
        },
        {
          "key": "C",
          "text": "6a² - 8a + 11"
        },
        {
          "key": "D",
          "text": "2a² - 8a + 3"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Subtract by changing signs: 4a² - 3a + 7 - 2a² - 5a + 4 = 2a² - 8a + 11."
    },
    {
      "id": "q4",
      "sectionId": "math",
      "globalIndex": 3,
      "text": "The product (2x - 3)(x + 4) equals:",
      "options": [
        {
          "key": "A",
          "text": "2x² + 5x - 12"
        },
        {
          "key": "B",
          "text": "2x² - 5x - 12"
        },
        {
          "key": "C",
          "text": "2x² + 11x - 12"
        },
        {
          "key": "D",
          "text": "2x² + 5x + 12"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Using FOIL: 2x·x + 2x·4 - 3·x - 3·4 = 2x² + 8x - 3x - 12 = 2x² + 5x - 12."
    },
    {
      "id": "q5",
      "sectionId": "math",
      "globalIndex": 4,
      "text": "Divide 12x³y² - 8x²y³ + 4x²y² by 4x²y²:",
      "options": [
        {
          "key": "A",
          "text": "3x - 2y + 1"
        },
        {
          "key": "B",
          "text": "3xy - 2y + 1"
        },
        {
          "key": "C",
          "text": "3x - 2y² + 1"
        },
        {
          "key": "D",
          "text": "3x - 2y + 4"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Dividing each term: 12x³y²/4x²y² = 3x, -8x²y³/4x²y² = -2y, 4x²y²/4x²y² = 1."
    },
    {
      "id": "q6",
      "sectionId": "math",
      "globalIndex": 5,
      "text": "If (a + b)² = 49 and ab = 10, then a² + b² equals:",
      "options": [
        {
          "key": "A",
          "text": "29"
        },
        {
          "key": "B",
          "text": "39"
        },
        {
          "key": "C",
          "text": "59"
        },
        {
          "key": "D",
          "text": "69"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Since (a+b)² = a² + 2ab + b², we have 49 = a² + b² + 20, so a² + b² = 29."
    },
    {
      "id": "q7",
      "sectionId": "math",
      "globalIndex": 6,
      "text": "Expand: (3x - 2y)²",
      "options": [
        {
          "key": "A",
          "text": "9x² - 12xy + 4y²"
        },
        {
          "key": "B",
          "text": "9x² + 12xy + 4y²"
        },
        {
          "key": "C",
          "text": "9x² - 6xy + 4y²"
        },
        {
          "key": "D",
          "text": "3x² - 12xy + 2y²"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Using (a-b)² = a² - 2ab + b²: (3x)² - 2(3x)(2y) + (2y)² = 9x² - 12xy + 4y²."
    },
    {
      "id": "q8",
      "sectionId": "math",
      "globalIndex": 7,
      "text": "The value of 103 × 97 using identities is:",
      "options": [
        {
          "key": "A",
          "text": "9991"
        },
        {
          "key": "B",
          "text": "9999"
        },
        {
          "key": "C",
          "text": "9981"
        },
        {
          "key": "D",
          "text": "10001"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Writing as (100+3)(100-3) = 100² - 3² = 10000 - 9 = 9991."
    },
    {
      "id": "q9",
      "sectionId": "math",
      "globalIndex": 8,
      "text": "If a + b + c = 10 and a² + b² + c² = 40, then ab + bc + ca equals:",
      "options": [
        {
          "key": "A",
          "text": "30"
        },
        {
          "key": "B",
          "text": "20"
        },
        {
          "key": "C",
          "text": "60"
        },
        {
          "key": "D",
          "text": "50"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Using (a+b+c)² = a² + b² + c² + 2(ab+bc+ca): 100 = 40 + 2(ab+bc+ca), so ab+bc+ca = 30."
    },
    {
      "id": "q10",
      "sectionId": "math",
      "globalIndex": 9,
      "text": "Factorise: 12x²y - 18xy² + 6xy",
      "options": [
        {
          "key": "A",
          "text": "6xy(2x - 3y + 1)"
        },
        {
          "key": "B",
          "text": "6xy(2x - 3y)"
        },
        {
          "key": "C",
          "text": "6x(2xy - 3y² + 1)"
        },
        {
          "key": "D",
          "text": "6xy(2x + 3y + 1)"
        }
      ],
      "correctAnswer": "A",
      "explanation": "The HCF of the three terms is 6xy; dividing each gives 2x, -3y, and 1."
    },
    {
      "id": "q11",
      "sectionId": "math",
      "globalIndex": 10,
      "text": "Factorise: x² - 16y²",
      "options": [
        {
          "key": "A",
          "text": "(x - 4y)(x + 4y)"
        },
        {
          "key": "B",
          "text": "(x - 8y)(x + 8y)"
        },
        {
          "key": "C",
          "text": "(x - 4y)²"
        },
        {
          "key": "D",
          "text": "(x + 4y)²"
        }
      ],
      "correctAnswer": "A",
      "explanation": "This is a difference of squares: a² - b² = (a-b)(a+b) with a = x and b = 4y."
    },
    {
      "id": "q12",
      "sectionId": "math",
      "globalIndex": 11,
      "text": "Factorise: x² + 7x + 12",
      "options": [
        {
          "key": "A",
          "text": "(x + 3)(x + 4)"
        },
        {
          "key": "B",
          "text": "(x + 2)(x + 6)"
        },
        {
          "key": "C",
          "text": "(x - 3)(x - 4)"
        },
        {
          "key": "D",
          "text": "(x + 1)(x + 12)"
        }
      ],
      "correctAnswer": "A",
      "explanation": "We need two numbers whose product is 12 and sum is 7: these are 3 and 4."
    },
    {
      "id": "q13",
      "sectionId": "math",
      "globalIndex": 12,
      "text": "Factorise by grouping: ax + ay + bx + by",
      "options": [
        {
          "key": "A",
          "text": "(a + b)(x + y)"
        },
        {
          "key": "B",
          "text": "(a - b)(x + y)"
        },
        {
          "key": "C",
          "text": "(a + b)(x - y)"
        },
        {
          "key": "D",
          "text": "(ab + xy)"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Group: a(x+y) + b(x+y) = (a+b)(x+y)."
    },
    {
      "id": "q14",
      "sectionId": "math",
      "globalIndex": 13,
      "text": "If 5(x - 3) = 3(x + 5), then x equals:",
      "options": [
        {
          "key": "A",
          "text": "15"
        },
        {
          "key": "B",
          "text": "5"
        },
        {
          "key": "C",
          "text": "10"
        },
        {
          "key": "D",
          "text": "-15"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Expanding: 5x - 15 = 3x + 15, so 2x = 30, giving x = 15."
    },
    {
      "id": "q15",
      "sectionId": "math",
      "globalIndex": 14,
      "text": "The sum of three consecutive integers is 78. The largest of the three is:",
      "options": [
        {
          "key": "A",
          "text": "27"
        },
        {
          "key": "B",
          "text": "25"
        },
        {
          "key": "C",
          "text": "26"
        },
        {
          "key": "D",
          "text": "28"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Let the integers be n-1, n, n+1; their sum is 3n = 78, so n = 26 and the largest is 27."
    },
    {
      "id": "q16",
      "sectionId": "math",
      "globalIndex": 15,
      "text": "A father is four times as old as his son. After 5 years, the father will be three times as old. The son's present age (in years) is:",
      "options": [
        {
          "key": "A",
          "text": "10"
        },
        {
          "key": "B",
          "text": "8"
        },
        {
          "key": "C",
          "text": "12"
        },
        {
          "key": "D",
          "text": "15"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Let son's age be x; father is 4x. Then 4x + 5 = 3(x + 5) gives 4x + 5 = 3x + 15, so x = 10."
    },
    {
      "id": "q17",
      "sectionId": "math",
      "globalIndex": 16,
      "text": "Solve for x: (x + 2)/3 - (x - 1)/4 = 2",
      "options": [
        {
          "key": "A",
          "text": "13"
        },
        {
          "key": "B",
          "text": "17"
        },
        {
          "key": "C",
          "text": "11"
        },
        {
          "key": "D",
          "text": "9"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Multiply through by 12: 4(x+2) - 3(x-1) = 24, giving 4x + 8 - 3x + 3 = 24, so x + 11 = 24 and x = 13."
    },
    {
      "id": "q18",
      "sectionId": "math",
      "globalIndex": 17,
      "text": "The solution of the system x + y = 7 and x - y = 3 is:",
      "options": [
        {
          "key": "A",
          "text": "x = 5, y = 2"
        },
        {
          "key": "B",
          "text": "x = 4, y = 3"
        },
        {
          "key": "C",
          "text": "x = 6, y = 1"
        },
        {
          "key": "D",
          "text": "x = 3, y = 4"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Adding the two equations: 2x = 10, so x = 5; then y = 7 - 5 = 2."
    },
    {
      "id": "q19",
      "sectionId": "math",
      "globalIndex": 18,
      "text": "If 2x + 3y = 12 and x = 3, then y equals:",
      "options": [
        {
          "key": "A",
          "text": "2"
        },
        {
          "key": "B",
          "text": "3"
        },
        {
          "key": "C",
          "text": "4"
        },
        {
          "key": "D",
          "text": "6"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Substituting x = 3: 6 + 3y = 12, so 3y = 6 and y = 2."
    },
    {
      "id": "q20",
      "sectionId": "math",
      "globalIndex": 19,
      "text": "Solve by elimination: 3x + 2y = 16, 5x - 2y = 8. The value of x is:",
      "options": [
        {
          "key": "A",
          "text": "3"
        },
        {
          "key": "B",
          "text": "4"
        },
        {
          "key": "C",
          "text": "2"
        },
        {
          "key": "D",
          "text": "5"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Adding the two equations eliminates y: 8x = 24, so x = 3."
    },
    {
      "id": "q21",
      "sectionId": "math",
      "globalIndex": 20,
      "text": "If a : b = 2 : 3 and b : c = 4 : 5, then a : c is:",
      "options": [
        {
          "key": "A",
          "text": "8 : 15"
        },
        {
          "key": "B",
          "text": "2 : 5"
        },
        {
          "key": "C",
          "text": "5 : 8"
        },
        {
          "key": "D",
          "text": "10 : 12"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Make b common: a:b = 8:12 and b:c = 12:15, so a:c = 8:15."
    },
    {
      "id": "q22",
      "sectionId": "math",
      "globalIndex": 21,
      "text": "If y varies inversely as x and y = 8 when x = 6, then y when x = 12 is:",
      "options": [
        {
          "key": "A",
          "text": "4"
        },
        {
          "key": "B",
          "text": "16"
        },
        {
          "key": "C",
          "text": "8"
        },
        {
          "key": "D",
          "text": "2"
        }
      ],
      "correctAnswer": "A",
      "explanation": "In inverse variation, xy = k, so k = 48; when x = 12, y = 48/12 = 4."
    },
    {
      "id": "q23",
      "sectionId": "math",
      "globalIndex": 22,
      "text": "The degree of the polynomial 5x³y² - 4x²y + 7xy⁴ + 2 is:",
      "options": [
        {
          "key": "A",
          "text": "5"
        },
        {
          "key": "B",
          "text": "4"
        },
        {
          "key": "C",
          "text": "3"
        },
        {
          "key": "D",
          "text": "6"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Degree of each term: 5, 3, 5, 0; the highest is 5 (from 5x³y² and 7xy⁴)."
    },
    {
      "id": "q24",
      "sectionId": "math",
      "globalIndex": 23,
      "text": "The zero of the polynomial p(x) = 3x - 12 is:",
      "options": [
        {
          "key": "A",
          "text": "4"
        },
        {
          "key": "B",
          "text": "-4"
        },
        {
          "key": "C",
          "text": "3"
        },
        {
          "key": "D",
          "text": "-3"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Setting p(x) = 0: 3x - 12 = 0, so x = 4."
    },
    {
      "id": "q25",
      "sectionId": "math",
      "globalIndex": 24,
      "text": "The remainder when x³ - 2x² + x + 1 is divided by (x - 1) is:",
      "options": [
        {
          "key": "A",
          "text": "1"
        },
        {
          "key": "B",
          "text": "0"
        },
        {
          "key": "C",
          "text": "2"
        },
        {
          "key": "D",
          "text": "-1"
        }
      ],
      "correctAnswer": "A",
      "explanation": "By the remainder theorem, the remainder equals p(1) = 1 - 2 + 1 + 1 = 1."
    },
    {
      "id": "q26",
      "sectionId": "math",
      "globalIndex": 25,
      "text": "If (x - 2) is a factor of x³ - 3x² + kx - 4, the value of k is:",
      "options": [
        {
          "key": "A",
          "text": "4"
        },
        {
          "key": "B",
          "text": "-4"
        },
        {
          "key": "C",
          "text": "2"
        },
        {
          "key": "D",
          "text": "8"
        }
      ],
      "correctAnswer": "A",
      "explanation": "By the factor theorem, p(2) = 0: 8 - 12 + 2k - 4 = 0, so 2k = 8 and k = 4."
    },
    {
      "id": "q27",
      "sectionId": "math",
      "globalIndex": 26,
      "text": "The discriminant of the quadratic 2x² - 5x + 3 is:",
      "options": [
        {
          "key": "A",
          "text": "1"
        },
        {
          "key": "B",
          "text": "49"
        },
        {
          "key": "C",
          "text": "-1"
        },
        {
          "key": "D",
          "text": "25"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Discriminant = b² - 4ac = 25 - 24 = 1."
    },
    {
      "id": "q28",
      "sectionId": "math",
      "globalIndex": 27,
      "text": "If the roots of x² - px + 12 = 0 are 3 and 4, the value of p is:",
      "options": [
        {
          "key": "A",
          "text": "7"
        },
        {
          "key": "B",
          "text": "-7"
        },
        {
          "key": "C",
          "text": "12"
        },
        {
          "key": "D",
          "text": "1"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Sum of roots = p = 3 + 4 = 7 (and product 3 × 4 = 12 confirms)."
    },
    {
      "id": "q29",
      "sectionId": "math",
      "globalIndex": 28,
      "text": "The 15th term of the AP 7, 10, 13, 16, ... is:",
      "options": [
        {
          "key": "A",
          "text": "49"
        },
        {
          "key": "B",
          "text": "52"
        },
        {
          "key": "C",
          "text": "46"
        },
        {
          "key": "D",
          "text": "45"
        }
      ],
      "correctAnswer": "A",
      "explanation": "nth term = a + (n-1)d = 7 + 14(3) = 7 + 42 = 49."
    },
    {
      "id": "q30",
      "sectionId": "math",
      "globalIndex": 29,
      "text": "The sum of the first 20 terms of the AP 2, 5, 8, 11, ... is:",
      "options": [
        {
          "key": "A",
          "text": "610"
        },
        {
          "key": "B",
          "text": "580"
        },
        {
          "key": "C",
          "text": "600"
        },
        {
          "key": "D",
          "text": "620"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Sum = (n/2)[2a + (n-1)d] = 10[4 + 19·3] = 10[4 + 57] = 10 × 61 = 610."
    }
  ]
}
